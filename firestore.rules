rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /slowMotionTrackerWorkspaces/{workspaceId} {
      // Podgląd dla użytkowników aplikacji (anonimowe logowanie w tle)
      allow read: if request.auth != null;

      // Edycja tylko dla administratora (konto Email/Password)
      allow write: if request.auth != null
                   && request.auth.token.email == "admin@slowtkaniny.local";
    }
  }
}
